modules = ["python-3.11", "postgresql-16"]

[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "postgresql"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mycoursor CLI"

[[workflows.workflow]]
name = "mycoursor CLI"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m mycoursor.main status"

[workflows.workflow.metadata]
outputType = "console"
